# =============================================================================
# WriteHaven — NAS-Deployment-Konfiguration (PostgreSQL)
# =============================================================================
# Anleitung:
#   1. Diese Datei kopieren:  cp .env.nas.example .env.nas
#   2. Alle Werte mit GROSS_BUCHSTABEN durch echte Werte ersetzen
#   3. Deployment starten:    docker compose -f docker-compose.nas.yml up -d
#
# Voraussetzungen auf dem NAS:
#   PostgreSQL muss laufen und eine Datenbank + User für WriteHaven vorhanden sein.
#   Falls noch nicht eingerichtet, folgende psql-Befehle als postgres-Admin ausführen:
#
#     psql -U postgres
#     CREATE USER writehaven WITH PASSWORD 'SICHERES_PASSWORT';
#     CREATE DATABASE writehaven OWNER writehaven;
#     \q
#
#   Außerdem muss PostgreSQL Verbindungen aus dem Docker-Netzwerk erlauben:
#   In pg_hba.conf (z.B. /var/lib/postgresql/data/pg_hba.conf) eintragen:
#     host  all  all  172.17.0.0/16  md5
#   In postgresql.conf:
#     listen_addresses = '*'
#   Danach PostgreSQL neu starten.
# =============================================================================

# =============================================================================
# DATENBANK — PostgreSQL auf dem NAS
# =============================================================================
# host.docker.internal zeigt auf den NAS-Host (funktioniert dank extra_hosts in
# docker-compose.nas.yml). Alternativ direkt die NAS-IP eintragen, z.B. 192.168.1.100
DATABASE_URL=postgresql+psycopg://writehaven:SICHERES_PASSWORT@host.docker.internal:5432/writehaven

# =============================================================================
# FLASK KONFIGURATION
# =============================================================================
FLASK_ENV=production

# =============================================================================
# SICHERHEIT — unbedingt ändern!
# Generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
SECRET_KEY=ZUFAELLIGER_SECRET_KEY_HIER_EINTRAGEN
SECURITY_PASSWORD_SALT=ZUFAELLIGER_SALT_HIER_EINTRAGEN
JWT_EXPIRATION_HOURS=24

# =============================================================================
# E-MAIL — für lokales NAS meist nicht nötig; 'console' gibt Mails im Log aus
# =============================================================================
EMAIL_BACKEND=console
SECURITY_EMAIL_SENDER=noreply@writehaven.local

# =============================================================================
# URLS — auf NAS-IP oder Hostnamen anpassen
# Beispiel mit IP:        http://192.168.1.100:8080
# Beispiel mit Hostname:  http://writehaven.nas.local
# =============================================================================
FRONTEND_URL=http://NAS_IP_ODER_HOSTNAME:8080
ALLOWED_ORIGINS=http://NAS_IP_ODER_HOSTNAME:8080

# =============================================================================
# ANTHROPIC / CLAUDE API (optional — für Schreibgeist-Feature)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# RESEND (optional — für Feedback-Mails)
# =============================================================================
# RESEND_API_KEY=re_...
# FEEDBACK_SENDER_EMAIL=onboarding@resend.dev
# FEEDBACK_RECEIVER_EMAIL=deine@email.de
